    <script>
        let startTime = Date.now();
        let answeredQuestions = new Set();

        // Initialize Tech Background
        function initTechBackground() {
            const bg = document.getElementById('techBg');
            
            // Binary Rain Columns
            for (let i = 0; i < 20; i++) {
                const binary = document.createElement('div');
                binary.className = 'binary-rain';
                binary.style.left = Math.random() * 100 + '%';
                binary.style.animationDuration = (Math.random() * 10 + 10) + 's';
                binary.style.animationDelay = Math.random() * 5 + 's';
                binary.textContent = Array(20).fill(0).map(() => Math.random() > 0.5 ? '1' : '0').join('');
                bg.appendChild(binary);
            }

            // Floating Code Snippets
            const codeSnippets = [
                'function init() { return true; }',
                'const data = await fetch("/api");',
                'if (user.auth) { login(); }',
                'class TechQuiz extends Component {}',
                'import { knowledge } from "./brain";',
                'while (learning) { improve(); }',
                'console.log("Hello World");',
                '<div class="success">100%</div>',
                'SELECT * FROM mastery WHERE level=expert',
                'git commit -m "aced it"'
            ];

            for (let i = 0; i < 6; i++) {
                const code = document.createElement('div');
                code.className = 'code-float';
                code.style.left = Math.random() * 80 + 10 + '%';
                code.style.top = Math.random() * 80 + 10 + '%';
                code.style.animationDelay = Math.random() * 10 + 's';
                code.style.animationDuration = (15 + Math.random() * 10) + 's';
                code.textContent = codeSnippets[i];
                bg.appendChild(code);
            }

            // Circuit Lines
            for (let i = 0; i < 8; i++) {
                const line = document.createElement('div');
                line.className = 'circuit-line';
                line.style.top = Math.random() * 100 + '%';
                line.style.width = (100 + Math.random() * 200) + 'px';
                line.style.animationDelay = Math.random() * 3 + 's';
                line.style.animationDuration = (3 + Math.random() * 2) + 's';
                bg.appendChild(line);
            }

            // Core Particles
            for (let i = 0; i < 15; i++) {
                const particle = document.createElement('div');
                particle.className = 'core-particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 2 + 's';
                particle.style.animationDuration = (2 + Math.random() * 2) + 's';
                bg.appendChild(particle);
            }

            // Tech Icons
            const icons = ['💻', '⚡', '🔮', '🚀', '💾', '🌐', '🔒', '⚙️'];
            for (let i = 0; i < 8; i++) {
                const icon = document.createElement('div');
                icon.className = 'tech-icon';
                icon.textContent = icons[i];
                icon.style.left = Math.random() * 90 + 5 + '%';
                icon.style.top = Math.random() * 90 + 5 + '%';
                icon.style.animationDelay = Math.random() * 5 + 's';
                icon.style.animationDuration = (10 + Math.random() * 10) + 's';
                bg.appendChild(icon);
            }

            // Matrix Digital Rain (Green characters)
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*';
            for (let i = 0; i < 15; i++) {
                const column = document.createElement('div');
                column.className = 'matrix-column';
                column.style.left = Math.random() * 100 + '%';
                column.style.animationDuration = (10 + Math.random() * 10) + 's';
                column.style.animationDelay = Math.random() * 5 + 's';
                column.textContent = Array(30).fill(0).map(() => chars[Math.floor(Math.random() * chars.length)]).join('');
                bg.appendChild(column);
            }

            // Hexagon Grid
            for (let i = 0; i < 10; i++) {
                const hex = document.createElement('div');
                hex.className = 'hexagon';
                hex.style.left = Math.random() * 90 + '%';
                hex.style.top = Math.random() * 90 + '%';
                hex.style.animationDelay = Math.random() * 4 + 's';
                bg.appendChild(hex);
            }

            // Data Streams
            for (let i = 0; i < 6; i++) {
                const stream = document.createElement('div');
                stream.className = 'data-stream';
                stream.style.top = Math.random() * 100 + '%';
                stream.style.animationDelay = Math.random() * 5 + 's';
                stream.style.animationDuration = (5 + Math.random() * 5) + 's';
                bg.appendChild(stream);
            }

            // Floating Tags
            const tags = ['<html>', 'CSS', 'JavaScript', 'Python', 'API', 'Cloud', 'AI', 'Data'];
            for (let i = 0; i < 8; i++) {
                const tag = document.createElement('div');
                tag.className = 'float-tag';
                tag.textContent = tags[i];
                tag.style.left = Math.random() * 85 + 5 + '%';
                tag.style.top = Math.random() * 85 + 5 + '%';
                tag.style.animationDelay = Math.random() * 10 + 's';
                tag.style.animationDuration = (15 + Math.random() * 10) + 's';
                bg.appendChild(tag);
            }

            // Connection Nodes
            for (let i = 0; i < 8; i++) {
                const node = document.createElement('div');
                node.className = 'node';
                node.style.left = Math.random() * 95 + '%';
                node.style.top = Math.random() * 95 + '%';
                node.style.animationDelay = Math.random() * 3 + 's';
                bg.appendChild(node);
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            initTechBackground();
            highlightCurrentQuestion();
            startTime = Date.now();
        });

        function handleAnswer(questionNum) {
            answeredQuestions.add(questionNum);
            updateProgress();
            
            const card = document.querySelector(`[data-question="${questionNum}"]`);
            card.classList.add('answered');
            card.classList.remove('current');
            
            setTimeout(() => highlightCurrentQuestion(), 300);
            
            const nextQ = questionNum + 1;
            if (nextQ <= 5 && !answeredQuestions.has(nextQ)) {
                setTimeout(() => {
                    const nextCard = document.querySelector(`[data-question="${nextQ}"]`);
                    if (nextCard) {
                        nextCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }, 500);
            }
        }

        function highlightCurrentQuestion() {
            document.querySelectorAll('.question-card').forEach((card, idx) => {
                const qNum = idx + 1;
                card.classList.remove('current');
                if (!answeredQuestions.has(qNum) && answeredQuestions.size === idx) {
                    card.classList.add('current');
                }
            });
        }

        function updateProgress() {
            const total = 5;
            const answered = answeredQuestions.size;
            const percentage = (answered / total) * 100;
            
            document.getElementById('progressBar').style.width = percentage + '%';
            document.getElementById('progressPercent').textContent = Math.round(percentage) + '%';
            document.getElementById('answeredCount').textContent = answered;
        }

        function calculateScore() {
            if (answeredQuestions.size < 5) {
                const container = document.querySelector('.container');
                container.style.animation = 'shake 0.5s ease';
                setTimeout(() => container.style.animation = '', 500);
                
                for (let i = 1; i <= 5; i++) {
                    if (!answeredQuestions.has(i)) {
                        const card = document.querySelector(`[data-question="${i}"]`);
                        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        card.style.borderColor = 'var(--error)';
                        setTimeout(() => card.style.borderColor = '', 1000);
                        break;
                    }
                }
                return;
            }

            document.getElementById('loader').style.display = 'flex';
            
            setTimeout(() => {
                document.getElementById('loader').style.display = 'none';
                showResults();
            }, 2000);
        }

        function showResults() {
            let score = 0;
            for (let i = 1; i <= 5; i++) {
                const selected = document.querySelector(`input[name="q${i}"]:checked`);
                if (selected) score += parseInt(selected.value);
            }

            const timeTaken = Math.floor((Date.now() - startTime) / 1000);
            const percentage = (score / 5) * 100;
            
            document.getElementById('quizForm').style.display = 'none';
            document.querySelector('.progress-wrapper').style.display = 'none';
            document.querySelector('.header').style.display = 'none';
            
            const resultContainer = document.getElementById('resultContainer');
            resultContainer.style.display = 'block';
            
            const circle = document.getElementById('scoreCircle');
            const circumference = 2 * Math.PI * 90;
            const offset = circumference - (percentage / 100) * circumference;
            
            setTimeout(() => {
                circle.style.strokeDashoffset = offset;
            }, 100);
            
            animateValue('scoreValue', 0, score, 1500);
            
            const trophy = document.getElementById('trophyIcon');
            const title = document.getElementById('resultTitle');
            const feedback = document.getElementById('feedbackText');
            
            let rank = '-';
            
            if (percentage === 100) {
                trophy.textContent = '👑';
                title.textContent = 'PERFECT_EXECUTION';
                feedback.textContent = 'System optimization: 100%. All modules executed flawlessly. Elite developer status achieved!';
                rank = 'S+';
                launchConfetti();
            } else if (percentage >= 80) {
                trophy.textContent = '🚀';
                title.textContent = 'HIGH_PERFORMANCE';
                feedback.textContent = 'Excellent processing power! Your tech knowledge is running at optimal efficiency.';
                rank = 'A+';
                launchConfetti();
            } else if (percentage >= 60) {
                trophy.textContent = '⭐';
                title.textContent = 'STABLE_OPERATION';
                feedback.textContent = 'Good system stability. Consider upgrading your knowledge modules for better performance.';
                rank = 'B';
            } else if (percentage >= 40) {
                trophy.textContent = '🔧';
                title.textContent = 'REQUIRES_DEBUGGING';
                feedback.textContent = 'System errors detected. Debug required. Review documentation and retry compilation.';
                rank = 'C';
            } else {
                trophy.textContent = '💻';
                title.textContent = 'CRITICAL_ERROR';
                feedback.textContent = 'Fatal exception thrown. Kernel panic avoided. Reboot recommended with study materials.';
                rank = 'D';
            }
            
            document.getElementById('accuracyStat').textContent = percentage + '%';
            document.getElementById('timeStat').textContent = timeTaken + 's';
            document.getElementById('rankStat').textContent = rank;
        }

        function animateValue(id, start, end, duration) {
            const obj = document.getElementById(id);
            const range = end - start;
            const increment = end > start ? 1 : -1;
            const stepTime = Math.abs(Math.floor(duration / range));
            let current = start;
            
            const timer = setInterval(() => {
                current += increment;
                obj.textContent = current;
                if (current === end) clearInterval(timer);
            }, stepTime);
        }

        function launchConfetti() {
            const colors = ['#6366f1', '#ec4899', '#06b6d4', '#10b981', '#f59e0b', '#ffffff'];
            
            for (let i = 0; i < 100; i++) {
                setTimeout(() => {
                    const particle = document.createElement('div');
                    particle.style.position = 'fixed';
                    particle.style.width = Math.random() * 10 + 5 + 'px';
                    particle.style.height = particle.style.width;
                    particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                    particle.style.left = Math.random() * 100 + 'vw';
                    particle.style.top = '-10px';
                    particle.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
                    particle.style.zIndex = '9999';
                    particle.style.pointerEvents = 'none';
                    particle.style.boxShadow = '0 0 10px currentColor';
                    
                    const duration = Math.random() * 3 + 2;
                    particle.style.animation = `fall ${duration}s linear forwards`;
                    
                    document.body.appendChild(particle);
                    
                    setTimeout(() => particle.remove(), duration * 1000);
                }, i * 30);
            }
        }

        function restartQuiz() {
            document.getElementById('quizForm').reset();
            answeredQuestions.clear();
            startTime = Date.now();
            
            document.getElementById('quizForm').style.display = 'block';
            document.querySelector('.progress-wrapper').style.display = 'block';
            document.querySelector('.header').style.display = 'block';
            document.getElementById('resultContainer').style.display = 'none';
            
            updateProgress();
            
            document.querySelectorAll('.question-card').forEach(card => {
                card.classList.remove('answered', 'current');
            });
            
            document.getElementById('scoreCircle').style.strokeDashoffset = 565;
            
            highlightCurrentQuestion();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Add shake animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                20%, 60% { transform: translateX(-10px); }
                40%, 80% { transform: translateX(10px); }
            }
        `;
        document.head.appendChild(style);
    </script>

</body>
</html>
