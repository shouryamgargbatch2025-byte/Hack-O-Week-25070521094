<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tech Mastery Challenge</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Code:wght@400;600&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --accent: #06b6d4;
            --dark: #0f172a;
            --light: #f8fafc;
            --success: #10b981;
            --warning: #f59e0b;
            --error: #ef4444;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: linear-gradient(-45deg, #0f172a, #1e1b4b, #312e81, #0f172a);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
            position: relative;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Tech Background Animation Container */
        .tech-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            background: radial-gradient(circle at center, #1e1b4b 0%, #0f172a 100%);
        }

        /* Binary Rain */
        .binary-rain {
            position: absolute;
            font-family: 'Fira Code', monospace;
            font-size: 14px;
            color: rgba(99, 102, 241, 0.3);
            writing-mode: vertical-rl;
            text-orientation: upright;
            animation: fall linear infinite;
            pointer-events: none;
        }

        @keyframes fall {
            0% { transform: translateY(-100vh); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(100vh); opacity: 0; }
        }

        /* Floating Code Snippets */
        .code-float {
            position: absolute;
            font-family: 'Fira Code', monospace;
            font-size: 12px;
            color: rgba(236, 72, 153, 0.2);
            background: rgba(255, 255, 255, 0.02);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            animation: codeFloat 20s ease-in-out infinite;
            pointer-events: none;
            white-space: pre;
        }

        @keyframes codeFloat {
            0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.3; }
            25% { transform: translate(30px, -30px) rotate(2deg); opacity: 0.6; }
            50% { transform: translate(-20px, -50px) rotate(-1deg); opacity: 0.4; }
            75% { transform: translate(20px, -20px) rotate(1deg); opacity: 0.5; }
        }

        /* Circuit Lines */
        .circuit-line {
            position: absolute;
            background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.3), transparent);
            height: 2px;
            animation: circuitFlow 3s linear infinite;
        }

        @keyframes circuitFlow {
            0% { transform: translateX(-100%); opacity: 0; }
            50% { opacity: 1; }
            100% { transform: translateX(100vw); opacity: 0; }
        }

        /* CPU/Core Particles */
        .core-particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent), 0 0 20px var(--accent);
            animation: corePulse 2s ease-in-out infinite;
        }

        @keyframes corePulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.5); opacity: 1; }
        }

        /* Floating Icons */
        .tech-icon {
            position: absolute;
            font-size: 2rem;
            opacity: 0.15;
            animation: iconFloat 15s ease-in-out infinite;
            filter: drop-shadow(0 0 10px currentColor);
        }

        @keyframes iconFloat {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-30px) rotate(10deg); }
        }

        /* Matrix Digital Rain Effect */
        .matrix-column {
            position: absolute;
            top: -100%;
            font-family: 'Fira Code', monospace;
            font-size: 16px;
            color: rgba(16, 185, 129, 0.4);
            text-shadow: 0 0 5px rgba(16, 185, 129, 0.6);
            animation: matrixFall linear infinite;
            white-space: nowrap;
        }

        @keyframes matrixFall {
            0% { transform: translateY(0); }
            100% { transform: translateY(200vh); }
        }

        /* Hexagon Grid */
        .hexagon {
            position: absolute;
            width: 60px;
            height: 34.64px;
            background: transparent;
            border-left: 2px solid rgba(99, 102, 241, 0.1);
            border-right: 2px solid rgba(99, 102, 241, 0.1);
            animation: hexPulse 4s ease-in-out infinite;
        }

        .hexagon:before,
        .hexagon:after {
            content: "";
            position: absolute;
            width: 42.43px;
            height: 42.43px;
            transform: scaleY(0.5774) rotate(-45deg);
            background: transparent;
            left: 6.7868px;
        }

        .hexagon:before {
            top: -21.2132px;
            border-top: 2px solid rgba(99, 102, 241, 0.1);
            border-right: 2px solid rgba(99, 102, 241, 0.1);
        }

        .hexagon:after {
            bottom: -21.2132px;
            border-bottom: 2px solid rgba(99, 102, 241, 0.1);
            border-left: 2px solid rgba(99, 102, 241, 0.1);
        }

        @keyframes hexPulse {
            0%, 100% { opacity: 0.1; transform: scale(1); }
            50% { opacity: 0.3; transform: scale(1.1); }
        }

        /* Data Stream Lines */
        .data-stream {
            position: absolute;
            width: 100px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            opacity: 0.3;
            animation: streamMove 8s linear infinite;
        }

        @keyframes streamMove {
            0% { transform: translateX(-100px) translateY(0); opacity: 0; }
            50% { opacity: 0.6; }
            100% { transform: translateX(calc(100vw + 100px)) translateY(50px); opacity: 0; }
        }

        /* Floating Tags */
        .float-tag {
            position: absolute;
            padding: 8px 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            font-family: 'Fira Code', monospace;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.3);
            animation: tagFloat 18s ease-in-out infinite;
        }

        @keyframes tagFloat {
            0%, 100% { transform: translate(0, 0) rotate(-2deg); }
            33% { transform: translate(20px, -40px) rotate(2deg); }
            66% { transform: translate(-10px, -20px) rotate(-1deg); }
        }

        /* Connection Nodes */
        .node {
            position: absolute;
            width: 8px;
            height: 8px;
            background: var(--secondary);
            border-radius: 50%;
            box-shadow: 0 0 15px var(--secondary);
            animation: nodeBlink 3s ease-in-out infinite;
        }

        @keyframes nodeBlink {
            0%, 100% { opacity: 0.3; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.2); }
        }

        .node::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 30px;
            height: 1px;
            background: linear-gradient(90deg, var(--secondary), transparent);
            transform-origin: left center;
            animation: nodeRotate 10s linear infinite;
        }

        @keyframes nodeRotate {
            from { transform: translate(-50%, -50%) rotate(0deg); }
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }

        /* Main Container */
        .container {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
            max-width: 900px;
            border-radius: 40px;
            padding: 50px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5),
                        inset 0 0 0 1px rgba(255, 255, 255, 0.05),
                        0 0 100px rgba(99, 102, 241, 0.1);
            position: relative;
            overflow: hidden;
            animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(40px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .container::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transition: left 0.7s;
        }

        .container:hover::before {
            left: 100%;
        }

        .header {
            text-align: center;
            margin-bottom: 50px;
            position: relative;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(236, 72, 153, 0.2));
            padding: 10px 24px;
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            color: white;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            animation: pulse 2s infinite;
            font-family: 'Fira Code', monospace;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
            50% { box-shadow: 0 0 0 15px rgba(99, 102, 241, 0); }
        }

        .header h2 {
            font-size: 3.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
            letter-spacing: -2px;
            line-height: 1.1;
        }

        .header p {
            color: rgba(255, 255, 255, 0.6);
            font-size: 1.25rem;
            font-weight: 400;
        }

        /* Progress Section */
        .progress-wrapper {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
        }

        .progress-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
            opacity: 0.5;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            color: white;
            font-weight: 600;
            font-family: 'Fira Code', monospace;
        }

        .progress-bar-container {
            height: 12px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
            background-size: 200% 100%;
            width: 0%;
            border-radius: 20px;
            transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            animation: shimmer 2s infinite;
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.5);
        }

        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: progressShine 2s infinite;
        }

        @keyframes progressShine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        /* Question Cards */
        .question-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 35px;
            margin-bottom: 25px;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .question-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .question-card:hover {
            transform: translateY(-5px) rotateX(2deg);
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 30px rgba(99, 102, 241, 0.1);
        }

        .question-card:hover::before {
            opacity: 1;
        }

        .question-card.answered {
            background: rgba(16, 185, 129, 0.05);
            border-color: rgba(16, 185, 129, 0.3);
            box-shadow: 0 0 30px rgba(16, 185, 129, 0.1);
        }

        .question-card.current {
            border-color: var(--primary);
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.2);
            animation: currentPulse 2s infinite;
        }

        @keyframes currentPulse {
            0%, 100% { box-shadow: 0 0 30px rgba(99, 102, 241, 0.2); }
            50% { box-shadow: 0 0 50px rgba(99, 102, 241, 0.4); }
        }

        .question-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 25px;
        }

        .question-number {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
            color: white;
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
            position: relative;
            overflow: hidden;
            font-family: 'Fira Code', monospace;
        }

        .question-number::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255,255,255,0.3), transparent);
            transform: rotate(45deg);
            transition: all 0.5s;
        }

        .question-card:hover .question-number::after {
            left: 100%;
        }

        .question-text {
            font-size: 1.4rem;
            font-weight: 600;
            color: white;
            line-height: 1.4;
            flex: 1;
        }

        .options {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .option {
            position: relative;
            cursor: pointer;
            perspective: 1000px;
        }

        .option input[type="radio"] {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }

        .option-label {
            display: flex;
            align-items: center;
            padding: 20px 25px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .option-label::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.3), transparent);
            transition: width 0.3s ease;
            z-index: 0;
        }

        .option:hover .option-label {
            transform: translateX(10px) scale(1.02);
            border-color: rgba(99, 102, 241, 0.3);
            background: rgba(255, 255, 255, 0.06);
        }

        .option:hover .option-label::before {
            width: 100%;
        }

        .option input[type="radio"]:checked + .option-label {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(236, 72, 153, 0.1));
            border-color: var(--primary);
            color: white;
            transform: translateX(15px) scale(1.02);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
        }

        .option-content {
            display: flex;
            align-items: center;
            gap: 15px;
            position: relative;
            z-index: 1;
            width: 100%;
        }

        .option-icon {
            width: 28px;
            height: 28px;
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
            position: relative;
        }

        .option-icon::before {
            content: '';
            width: 12px;
            height: 12px;
            background: white;
            border-radius: 50%;
            transform: scale(0);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .option input[type="radio"]:checked + .option-label .option-icon {
            border-color: white;
            background: white;
            transform: scale(1.1);
        }

        .option input[type="radio"]:checked + .option-label .option-icon::before {
            transform: scale(1);
            background: var(--primary);
        }

        .option-text {
            font-weight: 500;
        }

        /* Submit Button */
        .submit-container {
            margin-top: 40px;
            text-align: center;
        }

        .submit-btn {
            position: relative;
            padding: 20px 60px;
            font-size: 1.25rem;
            font-weight: 700;
            color: white;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 50px;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4),
                        0 0 0 0 rgba(99, 102, 241, 0.6);
            animation: submitPulse 2s infinite;
            font-family: 'Space Grotesk', sans-serif;
        }

        @keyframes submitPulse {
            0%, 100% { box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4), 0 0 0 0 rgba(99, 102, 241, 0.6); }
            50% { box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4), 0 0 0 20px rgba(99, 102, 241, 0); }
        }

        .submit-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.6s;
        }

        .submit-btn:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.5);
        }

        .submit-btn:hover::before {
            left: 100%;
        }

        .submit-btn:active {
            transform: translateY(-1px) scale(1.02);
        }

        .btn-text {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-icon {
            transition: transform 0.3s ease;
        }

        .submit-btn:hover .btn-icon {
            transform: translateX(5px);
        }

        /* Results Screen */
        .result-container {
            display: none;
            text-align: center;
            padding: 40px;
            animation: resultIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes resultIn {
            from { opacity: 0; transform: scale(0.8) translateY(40px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .trophy {
            font-size: 8rem;
            margin-bottom: 30px;
            display: inline-block;
            animation: trophyFloat 3s ease-in-out infinite;
            filter: drop-shadow(0 10px 30px rgba(255, 215, 0, 0.5));
        }

        @keyframes trophyFloat {
            0%, 100% { transform: translateY(0) rotate(-5deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        .result-title {
            font-size: 3rem;
            font-weight: 700;
            color: white;
            margin-bottom: 20px;
            text-shadow: 0 2px 20px rgba(0,0,0,0.3);
        }

        .score-circle {
            width: 200px;
            height: 200px;
            margin: 30px auto;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .score-svg {
            position: absolute;
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
        }

        .score-bg {
            fill: none;
            stroke: rgba(255, 255, 255, 0.1);
            stroke-width: 8;
        }

        .score-progress {
            fill: none;
            stroke: url(#scoreGradient);
            stroke-width: 8;
            stroke-linecap: round;
            stroke-dasharray: 565;
            stroke-dashoffset: 565;
            transition: stroke-dashoffset 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            filter: drop-shadow(0 0 10px rgba(99, 102, 241, 0.5));
        }

        .score-text {
            font-size: 4rem;
            font-weight: 800;
            color: white;
            z-index: 1;
            line-height: 1;
            font-family: 'Fira Code', monospace;
        }

        .score-label {
            font-size: 1.5rem;
            color: rgba(255, 255, 255, 0.6);
            font-weight: 500;
        }

        .feedback-box {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 30px;
            margin: 30px 0;
            backdrop-filter: blur(10px);
        }

        .feedback-text {
            font-size: 1.3rem;
            color: white;
            line-height: 1.6;
            font-weight: 500;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin: 30px 0;
        }

        .stat-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease;
        }

        .stat-item:hover {
            transform: translateY(-5px);
            border-color: rgba(99, 102, 241, 0.3);
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: white;
            display: block;
            font-family: 'Fira Code', monospace;
        }

        .stat-label {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.6);
            margin-top: 5px;
        }

        .restart-btn {
            padding: 18px 40px;
            font-size: 1.1rem;
            font-weight: 600;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 20px;
            backdrop-filter: blur(10px);
            font-family: 'Space Grotesk', sans-serif;
        }

        .restart-btn:hover {
            background: white;
            color: var(--primary);
            transform: translateY(-3px);
