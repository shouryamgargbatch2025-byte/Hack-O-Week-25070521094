<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simple Weather App</title>

<style>

body{
font-family: Arial, sans-serif;
background: linear-gradient(135deg,#74ebd5,#ACB6E5);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
margin:0;
}

.container{
background:white;
padding:30px;
border-radius:15px;
width:320px;
text-align:center;
box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

h1{
margin-bottom:20px;
}

.city-buttons{
margin-bottom:20px;
}

.city-buttons button{
padding:10px 15px;
margin:5px;
border:none;
border-radius:8px;
background:#4CAF50;
color:white;
cursor:pointer;
font-weight:bold;
}

.city-buttons button:hover{
background:#388E3C;
}

.weather{
margin-top:20px;
}

.temp{
font-size:40px;
font-weight:bold;
}

.condition{
font-size:20px;
color:#555;
}

.icon{
font-size:50px;
margin:10px 0;
}

</style>
</head>

<body>

<div class="container">

<h1>Weather</h1>

<div class="city-buttons">
<button onclick="showWeather('nagpur')">Nagpur</button>
<button onclick="showWeather('mumbai')">Mumbai</button>
<button onclick="showWeather('delhi')">Delhi</button>
</div>

<div class="weather">
<div id="cityName"></div>
<div class="icon" id="icon"></div>
<div class="temp" id="temp"></div>
<div class="condition" id="condition"></div>
</div>

</div>

<script>

const weatherData = {

nagpur:{
city:"Nagpur",
temp:"34°C",
condition:"Sunny",
icon:"☀️"
},

mumbai:{
city:"Mumbai",
temp:"30°C",
condition:"Humid",
icon:"🌤️"
},

delhi:{
city:"Delhi",
temp:"28°C",
condition:"Cloudy",
icon:"☁️"
}

};

function showWeather(city){

document.getElementById("cityName").innerHTML =
"<h2>"+weatherData[city].city+"</h2>";

document.getElementById("temp").innerText =
weatherData[city].temp;

document.getElementById("condition").innerText =
weatherData[city].condition;

document.getElementById("icon").innerText =
weatherData[city].icon;

}

showWeather("nagpur");

</script>

</body>
</html>
