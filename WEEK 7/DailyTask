```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Productivity Tracker</title>

<style>

*{
box-sizing:border-box;
font-family:Segoe UI, sans-serif;
}

body{
margin:0;
background:linear-gradient(135deg,#6a11cb,#2575fc);
display:flex;
justify-content:center;
padding:20px;
color:#333;
}

.container{
background:white;
width:100%;
max-width:900px;
padding:25px;
border-radius:15px;
box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

h1{
text-align:center;
margin-bottom:20px;
}

.taskControls{
display:flex;
flex-wrap:wrap;
gap:10px;
}

input,select{
padding:10px;
border-radius:6px;
border:1px solid #ccc;
}

button{
padding:10px 15px;
border:none;
border-radius:6px;
background:#2575fc;
color:white;
cursor:pointer;
}

button:hover{
opacity:.9;
}

ul{
list-style:none;
padding:0;
margin-top:20px;
}

li{
padding:10px;
margin-bottom:10px;
border-radius:6px;
display:flex;
justify-content:space-between;
align-items:center;
background:#f4f6fb;
}

.completed span{
text-decoration:line-through;
opacity:0.6;
}

input[type="checkbox"]{
width:18px;
height:18px;
cursor:pointer;
}

.dashboard{
margin-top:30px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
gap:15px;
}

.card{
background:#f4f6fb;
padding:15px;
border-radius:10px;
text-align:center;
font-weight:bold;
}

.timer{
margin-top:30px;
text-align:center;
}

.timerDisplay{
font-size:32px;
margin:10px 0;
}

.timeControls button{
margin:5px;
background:#28a745;
}

@media(max-width:600px){

.taskControls{
flex-direction:column;
}

}

</style>
</head>

<body>

<div class="container">

<h1>Smart Productivity Tracker</h1>

<div class="taskControls">
<input id="taskInput" placeholder="Enter task">
<input type="date" id="taskDate">
<select id="priority">
<option>High</option>
<option>Medium</option>
<option>Low</option>
</select>
<button onclick="addTask()">Add Task</button>
</div>

<ul id="taskList"></ul>

<div class="dashboard">

<div class="card">
Total Tasks
<div id="totalTasks">0</div>
</div>

<div class="card">
Completed
<div id="completedTasks">0</div>
</div>

<div class="card">
Completion %
<div id="completionRate">0%</div>
</div>

<div class="card">
Streak 🔥
<div id="streak">0 days</div>
</div>

</div>

<div class="timer">

<h2>Pomodoro Timer</h2>

<div class="timerDisplay" id="timer">25:00</div>

<div class="timeControls">
<button onclick="increaseTime()">+5 min</button>
<button onclick="decreaseTime()">-5 min</button>
</div>

<button onclick="startTimer()">Start</button>
<button onclick="resetTimer()">Reset</button>

</div>

</div>

<script>

let tasks = JSON.parse(localStorage.getItem("tasks")) || [];
let streak = localStorage.getItem("streak") || 0;

let time = 1500;
let interval;

Notification.requestPermission();

function save(){
localStorage.setItem("tasks",JSON.stringify(tasks));
}

function render(){

const list=document.getElementById("taskList");
list.innerHTML="";

let completed=0;

tasks.forEach((task,i)=>{

const li=document.createElement("li");

if(task.completed){
li.classList.add("completed");
completed++;
}

li.innerHTML = `
<label style="display:flex;align-items:center;gap:10px;">
<input type="checkbox" ${task.completed ? "checked" : ""} onchange="toggleTask(${i})">
<span>${task.text} (${task.date})</span>
</label>

<button onclick="deleteTask(${i})">❌</button>
`;

list.appendChild(li);

});

document.getElementById("totalTasks").textContent=tasks.length;
document.getElementById("completedTasks").textContent=completed;

let percent=tasks.length?Math.round((completed/tasks.length)*100):0;

document.getElementById("completionRate").textContent=percent+"%";
document.getElementById("streak").textContent=streak+" days";

save();

}

function addTask(){

let text=document.getElementById("taskInput").value;
let date=document.getElementById("taskDate").value;

if(text==="") return;

tasks.push({
text,
date,
completed:false
});

document.getElementById("taskInput").value="";

render();

}

function toggleTask(i){

tasks[i].completed=!tasks[i].completed;

updateStreak();

render();

}

function deleteTask(i){

tasks.splice(i,1);

render();

}

function updateStreak(){

let today=new Date().toDateString();

let last=localStorage.getItem("lastCompleted");

if(last!==today){
streak++;
localStorage.setItem("streak",streak);
localStorage.setItem("lastCompleted",today);
}

}

function checkReminders(){

let today=new Date().toISOString().split("T")[0];

tasks.forEach(task=>{

if(task.date===today && !task.completed){

new Notification("Task Reminder",{
body:task.text
});

}

});

}

setInterval(checkReminders,60000);

function updateTimer(){

let m=Math.floor(time/60);
let s=time%60;

document.getElementById("timer").textContent=
`${m}:${s.toString().padStart(2,'0')}`;

}

function startTimer(){

clearInterval(interval);

interval=setInterval(()=>{

time--;

updateTimer();

if(time<=0){

clearInterval(interval);

alert("Pomodoro complete!");

}

},1000);

}

function resetTimer(){

clearInterval(interval);
time=1500;
updateTimer();

}

function increaseTime(){

time+=300;
updateTimer();

}

function decreaseTime(){

if(time>300){
time-=300;
updateTimer();
}

}

updateTimer();
render();

</script>

</body>
</html>
```
